{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "ctf",
    "version": "0.1.0",
    "description": "A two-team capture-the-flag shooter. Red and Blue spawn on opposite edges, fight over a single neutral flag with one-shot-kill guns, and win by capturing the flag at their home edge or wiping the enemy team.",
    "owner": "treeform@softmax.com",
    "runnable": {
      "type": "game",
      "image": "ghcr.io/metta-ai/coworld-ctf:latest",
      "run": [
        "/bin/ctf"
      ]
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "players"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "players": {
          "description": "One player display-name object per player slot, indexed by slot.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "slots": {
          "description": "Optional fixed player slot team, color, and token settings.",
          "type": "array",
          "maxItems": 8,
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "token": {
                "type": "string"
              },
              "team": {
                "type": "string",
                "enum": [
                  "red",
                  "blue"
                ]
              },
              "color": {
                "type": "string",
                "enum": [
                  "red",
                  "orange",
                  "yellow",
                  "light blue",
                  "pink",
                  "lime",
                  "blue",
                  "pale blue",
                  "gray",
                  "white",
                  "dark brown",
                  "brown",
                  "dark teal",
                  "green",
                  "dark navy",
                  "black"
                ]
              }
            }
          }
        },
        "closedRoster": {
          "description": "Reject players outside the configured token/slot roster.",
          "type": "boolean",
          "default": false
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "default": 679961
        },
        "minPlayers": {
          "description": "Players needed before the game countdown starts.",
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 8
        },
        "lives": {
          "description": "Lives per player. Out of lives = out for the round.",
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "respawnTicks": {
          "description": "Ticks dead before respawning at home (~3s at 24 ticks/s).",
          "type": "integer",
          "minimum": 0,
          "default": 72
        },
        "spawnProtectTicks": {
          "description": "Ticks of spawn invulnerability after respawning (~1s).",
          "type": "integer",
          "minimum": 0,
          "default": 24
        },
        "gunRange": {
          "description": "Maximum hitscan gun range in pixels.",
          "type": "integer",
          "minimum": 1,
          "default": 150
        },
        "gunConeDeg": {
          "description": "Firing cone half-angle in degrees around the facing direction.",
          "type": "integer",
          "minimum": 0,
          "maximum": 180,
          "default": 25
        },
        "fireCooldownTicks": {
          "description": "Minimum ticks between shots (~0.5s at 24 ticks/s).",
          "type": "integer",
          "minimum": 0,
          "default": 12
        },
        "carrierSpeedPct": {
          "description": "Movement speed percentage while carrying the flag.",
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 70
        },
        "flagReturnTicks": {
          "description": "Idle ticks before a dropped flag returns to center (~8s).",
          "type": "integer",
          "minimum": 0,
          "default": 192
        },
        "startWaitTicks": {
          "description": "Lobby countdown ticks after enough players join.",
          "type": "integer",
          "minimum": 0,
          "default": 120
        },
        "gameOverTicks": {
          "description": "Game over display duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 360
        },
        "maxTicks": {
          "description": "Maximum game ticks before tiebreak, where 0 means no limit.",
          "type": "integer",
          "minimum": 0,
          "default": 10000
        },
        "maxGames": {
          "description": "Maximum games before shutdown.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "showPlayerLabels": {
          "description": "Show player labels.",
          "type": "boolean",
          "default": true
        },
        "mapPath": {
          "description": "Arena map identifier (procedurally generated).",
          "type": "string",
          "default": "arena"
        },
        "num_agents": {
          "description": "Number of agent seats; must equal the player slot count. Used by the team commissioner for block seating.",
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 8
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One scalar score per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "number"
          }
        },
        "win": {
          "description": "One win flag per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "boolean"
          }
        },
        "team": {
          "description": "One team name (red or blue) per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string"
          }
        },
        "kills": {
          "description": "One kill count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "deaths": {
          "description": "One death count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "captures": {
          "description": "One flag-capture count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-ctf/blob/master/README.md"
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "Rules",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/coworld-ctf/blob/master/docs/RULES.md"
          }
        }
      ]
    }
  },
  "player": [
    {
      "id": "baseline",
      "name": "baseline",
      "type": "player",
      "description": "Minimal sprite-protocol CTF baseline bot: grab the flag, run it home, shoot enemies in front. Image placeholder is replaced at deploy time.",
      "image": "ghcr.io/metta-ai/coworld-ctf-baseline:latest",
      "run": [
        "/bin/baseline"
      ]
    }
  ],
  "commissioner": [
    {
      "id": "ctf-commissioner",
      "name": "CTF Commissioner",
      "type": "commissioner",
      "description": "Config-driven ruleset-strategy commissioner for CTF: team_blocks seating with team_count 2 (Red/Blue, 4 seats each), win-based EWMA leaderboard. Defined by configs/ctf.yaml (RULESET_STRATEGY_CONFIG_NAME=ctf, baked into the image). Requires num_agents:8 in the variant game_config.",
      "source_url": "https://github.com/Metta-AI/commissioners/tree/main/commissioners/ruleset_strategy_commissioner",
      "image": "ghcr.io/metta-ai/commissioners-ctf:latest"
    }
  ],
  "reporter": [
    {
      "id": "ctf-eventlog-reporter",
      "name": "CTF Event-Log Reporter",
      "type": "reporter",
      "description": "Placeholder reporter that expands a completed CTF episode replay into a structured event log. Deployment artifact owned by another worker.",
      "source_url": "https://github.com/Metta-AI/coworld-ctf/tree/main/reporters/eventlog",
      "image": "ghcr.io/metta-ai/reporters-ctf-eventlog:latest"
    }
  ],
  "grader": [
    {
      "id": "ctf-grader",
      "name": "CTF Grader",
      "type": "grader",
      "description": "Placeholder CTF grader that scores episodes from team wins. Deployment artifact owned by another worker.",
      "source_url": "https://github.com/Metta-AI/graders/tree/main/graders/ctf/ctf_grader",
      "image": "ghcr.io/metta-ai/graders-ctf:latest"
    }
  ],
