  ],
  "commissioner": [
    {
      "id": "ctf-commissioner",
      "name": "CTF Commissioner",
      "type": "commissioner",
      "description": "Config-driven ruleset-strategy commissioner for CTF: team_blocks seating with team_count 2 (Red/Blue, 8 seats each), win-based EWMA leaderboard. Defined by configs/ctf.yaml (RULESET_STRATEGY_CONFIG_NAME=ctf, baked into the image). Requires num_agents:16 in the variant game_config.",
      "source_url": "https://github.com/Metta-AI/coworld-tools/tree/main/commissioners/commissioners/ruleset_strategy_commissioner",
      "image": "{{COMMISSIONER_IMAGE}}"
    }
  ],
