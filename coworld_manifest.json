{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "tags": [
    "shooter",
    "team",
    "ctf"
  ],
  "game": {
    "name": "ctf",
    "description": "A two-team capture-the-heart shooter with fog-of-war vision. Red and Blue spawn on opposite edges, each guarding a heart on its home pedestal. Steal the enemy heart and carry it home - or wipe the enemy team. Two med kits on the center line heal the hurt back to full and respawn after 30 seconds. Grenade pickups wait in the corners: charged throws sail over walls and burst on landing, heard but not seen through the fog. Two plasma arcs spawn high in the side back columns: a carried arc disables your gun and turns the trigger into a forward plasma cone - 4 squares of reach, 2 squares wide at the tip - that stays lit for 5 ticks, takes 20 ticks to reset, and deals 3 damage per touch (lethal to a bare cog; a shield carrier survives one). One shield sits low in each endzone's back column, vertically opposite the plasma arcs: carrying it grants 6 hit points but makes your fire rate 3x slower. Both are lost on death and respawn 30 seconds after being taken (see docs/RULES.md, Plasma arc and Shields). Aim is decoupled from movement and carries your vision cone; guns are map-wide 3-hit-point hitscan with a trigger windup, teammates are fogged like enemies, and unseen gunfire is heard as a jittered sound ring - never pinpointed. Players can shout: 10-character messages heard within a fifth of the field, tagged by player and team at jittered coordinates and drawn as speech bubbles in replays. Rendered in painted high-resolution art: observation coordinates arrive at 3x map scale since 0.6.0 (see docs/RULES.md, Observation render scale).",
    "owner": "treeform@softmax.com",
    "runnable": {
      "type": "game",
      "image": "{{GAME_IMAGE}}",
      "run": [
        "/bin/ctf"
      ],
      "source_url": "https://github.com/Metta-AI/coworld-ctf/tree/main"
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "players"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 16,
          "maxItems": 16,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "players": {
          "description": "One player display-name object per player slot, indexed by slot.",
          "type": "array",
          "minItems": 16,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "slots": {
          "description": "Optional fixed player slot team, color, and token settings.",
          "type": "array",
          "maxItems": 16,
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "token": {
                "type": "string"
              },
              "team": {
                "type": "string",
                "enum": [
                  "red",
                  "blue"
                ]
              },
              "color": {
                "type": "string",
                "enum": [
                  "red",
                  "orange",
                  "yellow",
                  "light blue",
                  "pink",
                  "lime",
                  "blue",
                  "pale blue",
                  "gray",
                  "white",
                  "dark brown",
                  "brown",
                  "dark teal",
                  "green",
                  "dark navy",
                  "black"
                ]
              }
            }
          }
        },
        "closedRoster": {
          "description": "Reject players outside the configured token/slot roster.",
          "type": "boolean",
          "default": false
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "default": 679961
        },
        "minPlayers": {
          "description": "Players needed before the game countdown starts.",
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 16
        },
        "lives": {
          "description": "Lives per player. Out of lives = out for the round.",
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "hitPoints": {
          "description": "Hit points per life. Each shot removes one; at zero you die.",
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "respawnTicks": {
          "description": "Ticks dead before respawning at home (~3s at 24 ticks/s).",
          "type": "integer",
          "minimum": 0,
          "default": 72
        },
        "spawnProtectTicks": {
          "description": "Ticks of spawn invulnerability after respawning (~1s).",
          "type": "integer",
          "minimum": 0,
          "default": 24
        },
        "gunRange": {
          "description": "Maximum hitscan gun range in pixels.",
          "type": "integer",
          "minimum": 1,
          "default": 1300
        },
        "fireCooldownTicks": {
          "description": "Minimum ticks between shots (~0.5s at 24 ticks/s).",
          "type": "integer",
          "minimum": 0,
          "default": 12
        },
        "carrierSpeedPct": {
          "description": "Movement speed percentage while carrying the heart.",
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 70
        },
        "playerBouncePct": {
          "description": "Restitution of player-player body collisions in percent: player bodies are solid and cannot pass through each other; 0 makes contact a dead-stop shove, 100 a perfectly elastic billiard bounce.",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 40
        },
        "aimTurnRate": {
          "description": "Aim rotation speed in brads (256ths of a turn) per tick while a rotate button is held. B rotates counter-clockwise, Select clockwise; movement never changes the aim.",
          "type": "integer",
          "minimum": 1,
          "default": 5
        },
        "visionConeDeg": {
          "description": "Vision cone half-angle in degrees around the aim angle. Fog of war hides everything outside the cone, the vision bubble, and line of sight.",
          "type": "integer",
          "minimum": 0,
          "maximum": 180,
          "default": 60
        },
        "visionBubble": {
          "description": "Omnidirectional vision radius in pixels around each player, seen regardless of aim.",
          "type": "integer",
          "minimum": 0,
          "default": 90
        },
        "startWaitTicks": {
          "description": "Lobby countdown ticks after enough players join.",
          "type": "integer",
          "minimum": 0,
          "default": 120
        },
        "gameOverTicks": {
          "description": "Game over display duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 360
        },
        "maxTicks": {
          "description": "Maximum game ticks before tiebreak, where 0 means no limit.",
          "type": "integer",
          "minimum": 0,
          "default": 10000
        },
        "maxGames": {
          "description": "Maximum games before shutdown.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "showPlayerLabels": {
          "description": "Show player labels.",
          "type": "boolean",
          "default": true
        },
        "mapPath": {
          "description": "Arena map identifier (procedurally generated).",
          "type": "string",
          "default": "arena"
        },
        "num_agents": {
          "description": "Number of agent seats; must equal the player slot count. Used by the team commissioner for block seating.",
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 16
        },
        "fireWindupTicks": {
          "description": "Ticks from trigger pull to the shot releasing (~0.2s at 24 ticks/s). Aim locks at the pull; a peeking target can duck back behind cover before the bullet leaves.",
          "type": "integer",
          "minimum": 0,
          "default": 5
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One scalar score per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "number"
          }
        },
        "win": {
          "description": "One win flag per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "boolean"
          }
        },
        "team": {
          "description": "One team name (red or blue) per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "string"
          }
        },
        "kills": {
          "description": "One kill count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "deaths": {
          "description": "One death count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "captures": {
          "description": "One heart-capture count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-ctf/blob/master/README.md"
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "Rules",
          "content": {
            "type": "uri",
            "value": "https://github.com/Metta-AI/coworld-ctf/blob/master/docs/RULES.md"
          }
        }
      ]
    }
  },
  "player": [
    {
      "id": "baseline",
      "name": "baseline",
      "type": "player",
      "description": "Minimal sprite-protocol CTF baseline bot: grab the flag, run it home, shoot enemies in front. Image placeholder is replaced at deploy time.",
