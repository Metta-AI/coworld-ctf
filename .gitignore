# Ignore files with no extention.
*
!*/
!*.*
!LICENSE
!Dockerfile

# Ignore hidden files, but not the license or github files.
.*
!.github/
!.github/**
!.gitignore
!.dockerignore

# Normal ignores.
nim.cfg
*.exe
nimcache
*.pdb
*.ilk
*.out
out/
tmp/
build/
replay-viewer/dist/
__pycache__/
*.pyc
*.dylib
*.dylib.abi
*.log
.DS_Store

# Project specific ignores.
client/screenshots/
players/modulabot/modulabot
players/modulabot/test/parity

# nanobanana art generation scratch (not shipped). Anchored to the repo root so
# it catches only /art/gen — the League Replayer's shipped dungeon-wall textures
# under client/art/walls/ ARE part of the build (staticRead into the server).
/art/
